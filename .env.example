# Copy this to .env.local and fill in your values

# Solana network (devnet | mainnet-beta | testnet)
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# RPC endpoint (optional - defaults to public endpoint)
# Use a paid RPC for production: Helius, QuickNode, Alchemy
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Server port
PORT=3000

# Your house wallet (receives bets, pays winners)
# HOUSE_WALLET=YOUR_SOLANA_WALLET_ADDRESS_HERE
